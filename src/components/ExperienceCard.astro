---
import LogoBadge from "./LogoBadge.astro";
import { withBase } from "../utils/paths";

interface Props {
  href: string;
  company: string;
  role: string;
  years: string;
  summary: string;
  heroImage: string;
  logoText?: string;
  logoImage?: string;
}

const { href, company, role, years, summary, heroImage, logoText, logoImage } = Astro.props;
---

<article class="experience-card">
  <a class="experience-card__link" href={href}>
    <div class="experience-card__masthead">
      <LogoBadge company={company} logoText={logoText} logoImage={logoImage} />
      <div class="experience-card__meta">
        <p>{years}</p>
        <h3>{company}</h3>
        <span>{role}</span>
      </div>
    </div>
    <img class="experience-card__image" src={withBase(heroImage)} alt={company} loading="lazy" />
    <div class="experience-card__body">
      <p>{summary}</p>
    </div>
  </a>
</article>
