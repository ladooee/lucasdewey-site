---
import { getCollection } from "astro:content";
import BaseLayout from "../../../layouts/BaseLayout.astro";
import ExperienceCard from "../../../components/ExperienceCard.astro";

const experiences = (await getCollection("experiences"))
  .sort((a, b) => a.data.order - b.data.order);
---

<BaseLayout title="Experience | Lucas Dewey" description="Company-based mechanical engineering experience.">
  <section class="section">
    <div class="shell section__header">
      <div>
        <p class="eyebrow">Portfolio</p>
        <h1 class="page-title">Experience</h1>
      </div>
    </div>
    <div class="shell experience-grid">
      {experiences.map((experience) => (
        <ExperienceCard
          href={`/portfolio/experience/${experience.id}/`}
          company={experience.data.company}
          role={experience.data.role}
          years={experience.data.years}
          summary={experience.data.summary}
          heroImage={experience.data.heroImage}
          logoText={experience.data.logoText}
          logoImage={experience.data.logoImage}
        />
      ))}
    </div>
  </section>
</BaseLayout>
