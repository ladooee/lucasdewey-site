---
import { getCollection } from "astro:content";
import BaseLayout from "../../../layouts/BaseLayout.astro";
import LogoBadge from "../../../components/LogoBadge.astro";

export async function getStaticPaths() {
  const experiences = await getCollection("experiences");

  return experiences.map((experience) => ({
    params: { slug: experience.id },
    props: { experience }
  }));
}

const { experience } = Astro.props;
---

<BaseLayout title={`${experience.data.company} | Lucas Dewey`} description={experience.data.summary}>
  <article class="experience-page">
    <section class="section">
      <div class="shell company-hero">
        <div class="company-hero__copy">
          <a class="text-link" href="/portfolio/experience/">Back to experience</a>
          <p class="eyebrow">{experience.data.years}</p>
          <h1>{experience.data.company}</h1>
          <p class="hero__role">{experience.data.role}</p>
          <p class="project-hero__summary">{experience.data.summary}</p>
          <div class="company-facts">
            <div>
              <span>Location</span>
              <strong>{experience.data.location}</strong>
            </div>
          </div>
        </div>
        <div class="company-hero__media">
          <LogoBadge
            company={experience.data.company}
            logoText={experience.data.logoText}
            logoImage={experience.data.logoImage}
            className="experience-logo--hero"
          />
          <img class="project-hero__image" src={experience.data.heroImage} alt={experience.data.company} />
        </div>
      </div>
    </section>

    <section class="section section--tight section--compact-bottom">
      <div class="shell two-column">
        <div class="detail-block">
          <h2>Highlights</h2>
          <ul>
            {experience.data.highlights.map((item) => <li>{item}</li>)}
          </ul>
        </div>
        <div class="detail-block">
          <h2>Tools</h2>
          <div class="tool-list">
            {experience.data.tools.map((tool) => <span>{tool}</span>)}
          </div>
        </div>
      </div>
    </section>

    {experience.data.publicRecognition && (
      <section class="section section--tight section--compact-bottom">
        <div class="shell">
          <div class="recognition-block">
            <div class="recognition-block__copy">
              <p class="eyebrow">Public recognition</p>
              <p>{experience.data.publicRecognition.summary}</p>
              {experience.data.publicRecognition.excerpt && (
                <p class="recognition-block__excerpt">
                  "{experience.data.publicRecognition.excerpt}"
                </p>
              )}
              <a
                class="text-link"
                href={experience.data.publicRecognition.sourceUrl}
                target="_blank"
                rel="noreferrer"
              >
                Source: {experience.data.publicRecognition.sourceLabel}
              </a>
            </div>
            {experience.data.publicRecognition.image && (
              <img
                class="recognition-block__image"
                src={experience.data.publicRecognition.image}
                alt={`${experience.data.company} recognition`}
                loading="lazy"
              />
            )}
          </div>
        </div>
      </section>
    )}

    <section class="section">
      <div class="shell section__header">
        <div>
          <p class="eyebrow">Projects</p>
          <h2>Work at {experience.data.company}</h2>
        </div>
      </div>
      <div class="shell project-stack">
        {experience.data.projects.map((project) => (
          <section class={`company-project ${!project.images || project.images.length === 0 ? "company-project--text-only" : ""}`}>
            <div class="company-project__copy">
              <p class="eyebrow">Project</p>
              <h3>{project.title}</h3>
              <p>{project.summary}</p>
              <h4>Contribution</h4>
              <ul>
                {project.contribution.map((item) => <li>{item}</li>)}
              </ul>
              <h4>Result</h4>
              <p>{project.result}</p>
            </div>
            {project.images && project.images.length > 0 && (
              <div class={`company-project__gallery company-project__gallery--count-${Math.min(project.images.length, 6)}`}>
                {project.images.map((image, index) => (
                  <figure class="gallery-item">
                    <img src={image} alt={`${project.title} image ${index + 1}`} loading="lazy" />
                  </figure>
                ))}
              </div>
            )}
          </section>
        ))}
      </div>
    </section>
  </article>
</BaseLayout>
