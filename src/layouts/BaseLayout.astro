---
import "../styles/global.css";
import { siteConfig } from "../site-config";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = `${siteConfig.name} | ${siteConfig.title}`,
  description = siteConfig.title
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="robots" content="noindex, nofollow" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
  </head>
  <body>
    <header class="site-header">
      <div class="shell site-header__inner">
        <a class="site-mark" href="/portfolio/">{siteConfig.name}</a>
        <nav class="site-nav" aria-label="Primary">
          <a href="/portfolio/experience/">Experience</a>
          <a href={siteConfig.contactUrl}>Contact</a>
        </nav>
      </div>
    </header>
    <main>
      <slot />
    </main>
    <footer class="site-footer">
      <div class="shell site-footer__inner">
        <p>© Lucas Dewey. Portfolio content is limited to public or non-confidential work. Confidential project details, implementation specifics, and proprietary visuals are intentionally omitted.</p>
      </div>
    </footer>
  </body>
</html>
