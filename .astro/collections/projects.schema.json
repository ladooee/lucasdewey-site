{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "title": {
      "type": "string"
    },
    "summary": {
      "type": "string"
    },
    "order": {
      "type": "number"
    },
    "featured": {
      "default": false,
      "type": "boolean"
    },
    "year": {
      "type": "string"
    },
    "status": {
      "default": "Completed",
      "type": "string"
    },
    "coverImage": {
      "type": "string"
    },
    "gallery": {
      "minItems": 1,
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "overview": {
      "type": "string"
    },
    "problem": {
      "type": "string"
    },
    "role": {
      "minItems": 1,
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "constraints": {
      "minItems": 1,
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "process": {
      "minItems": 1,
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "result": {
      "type": "string"
    },
    "tools": {
      "minItems": 1,
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "$schema": {
      "type": "string"
    }
  },
  "required": [
    "title",
    "summary",
    "order",
    "year",
    "coverImage",
    "gallery",
    "overview",
    "problem",
    "role",
    "constraints",
    "process",
    "result",
    "tools"
  ]
}